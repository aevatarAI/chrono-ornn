{
  "name": "chrono-ornn",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "ornn-skill",
    "ornn-frontend"
  ],
  "scripts": {
    "dev": "bun run dev:skill",
    "dev:skill": "bun run --filter ornn-skill dev",
